# Server
PORT=4000
NODE_ENV=development

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3
S3_BUCKET_NAME=pet-image-processor
S3_ORIGINAL_PREFIX=original-images
S3_PROCESSED_PREFIX=processed-images

# SQS – must be a real queue URL (not a placeholder). Example:
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-queue-name
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/pet-image-processing

# Upload limits
MAX_FILE_SIZE_MB=5

# Worker configuration
WORKER_POLL_INTERVAL_MS=2000

# Job settings
JOB_STATUS_TTL_MINUTES=60
