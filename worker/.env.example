# AWS (same as backend)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 (same bucket as backend)
S3_BUCKET_NAME=pet-image-processor
S3_ORIGINAL_PREFIX=original-images
S3_PROCESSED_PREFIX=processed-images

# SQS (same queue URL as backend)
SQS_QUEUE_URL=xxx

# Poll interval in ms
WORKER_POLL_INTERVAL_MS=2000

# Backend API base URL (for job status updates)
BACKEND_BASE_URL=http://localhost:4000
